# Environment Variables Template
# Copy this file to .env and fill in your actual values
# DO NOT COMMIT .env FILE TO GIT - IT CONTAINS PASSWORDS!

# PostgreSQL Database Configuration
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD_HERE@127.0.0.1:5432/crypto_predictions
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=YOUR_PASSWORD_HERE
DB_NAME=crypto_predictions

# Kraken API Configuration (for future live data ingestion)
KRAKEN_API_KEY=your_api_key_here
KRAKEN_API_SECRET=your_api_secret_here

# Optional: Flask/API Configuration
FLASK_ENV=development
SECRET_KEY=your_secret_key_here
